{
  "manifest_version": 3,
  "name": "gguf",
  "version": "0.0.1",
  "description": "View and edit GGUF model file metadata and tensor info directly in your browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "gguf",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": []
}
